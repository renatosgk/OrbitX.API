# ── Orbit X Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# ── Database (Oracle FIAP) ────────────────────────────────────────────────────
DATABASE_USERNAME=rm559810
DATABASE_PASSWORD=your_password_here

# ── AI — Groq API key (https://console.groq.com) ─────────────────────────────
# Leave empty to use the built-in KeywordAssistantService fallback (no LLM).
GROQ_API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_minimum

# ── RabbitMQ (optional — defaults to localhost guest/guest) ───────────────────
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
